# 服务器配置
PORT=3000
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# 地图服务商配置：amap（高德，默认）或 baidu（百度）
MAP_PROVIDER=amap

# 高德地图API配置
# 请在 https://console.amap.com/dev/key/app 申请您的API密钥
AMAP_API_KEY=your_amap_api_key_here
AMAP_SECURITY_KEY=your_amap_security_key_here

# 百度地图API配置
# 请在 https://lbsyun.baidu.com/apiconsole/key 申请您的API密钥
BAIDU_MAP_API_KEY=your_baidu_map_api_key_here
